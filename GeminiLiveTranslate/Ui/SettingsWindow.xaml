<Window x:Class="GeminiLiveTranslate.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini Live Translate Settings"
        Width="560"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="API Key" />
        <PasswordBox x:Name="ApiKeyBox" Margin="0,4,0,12" />

        <TextBlock Text="API Base URL" />
        <TextBox x:Name="ApiBaseBox" Margin="0,4,0,12" />

        <TextBlock Text="Proxy URL" />
        <TextBox x:Name="ProxyBox" Margin="0,4,0,12" />

        <TextBlock Text="Model" />
        <TextBox x:Name="ModelBox" Margin="0,4,0,12" />

        <TextBlock Text="Target Language" />
        <ComboBox x:Name="LanguageBox" Margin="0,4,0,12">
          <ComboBoxItem Content="zh-CN" />
          <ComboBoxItem Content="zh-TW" />
          <ComboBoxItem Content="en" />
          <ComboBoxItem Content="ja" />
          <ComboBoxItem Content="ko" />
          <ComboBoxItem Content="es" />
          <ComboBoxItem Content="fr" />
          <ComboBoxItem Content="de" />
          <ComboBoxItem Content="it" />
          <ComboBoxItem Content="pt" />
          <ComboBoxItem Content="vi" />
        </ComboBox>

        <TextBlock Text="Audio Source" />
        <ComboBox x:Name="AudioSourceBox" Margin="0,4,0,12">
          <ComboBoxItem Content="system" />
          <ComboBoxItem Content="mic" />
        </ComboBox>

        <TextBlock Text="Mic Device Number (-1 uses default)" />
        <TextBox x:Name="DeviceBox" Margin="0,4,0,12" />

        <CheckBox x:Name="EchoBox" Content="Play translated interpretation audio" Margin="0,0,0,10" />
        <CheckBox x:Name="ShowOriginalBox" Content="Show source transcript" Margin="0,0,0,12" />

        <TextBlock Text="Playback Volume (0.0 - 1.0)" />
        <TextBox x:Name="VolumeBox" Margin="0,4,0,12" />

        <TextBlock Text="HUD Font Size" />
        <TextBox x:Name="FontSizeBox" Margin="0,4,0,12" />

        <TextBlock Text="HUD Background Opacity (0.2 - 0.95)" />
        <TextBox x:Name="OpacityBox" Margin="0,4,0,12" />

        <TextBlock Text="System Prompt" />
        <TextBox x:Name="PromptBox" Margin="0,4,0,12" Height="88" TextWrapping="Wrap" AcceptsReturn="True" />
      </StackPanel>
    </ScrollViewer>
    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Width="88" Height="32" Content="Cancel" IsCancel="True" Margin="0,0,8,0" />
      <Button Width="88" Height="32" Content="Save" IsDefault="True" Click="SaveButton_OnClick" />
    </StackPanel>
  </Grid>
</Window>
